PORT=3000
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nurtura
DB_USER=postgres
DB_PASSWORD=postgres

# Production (Neon / Render / Supabase) — use one connection string:
# DATABASE_URL=postgresql://user:pass@host/nurtura?sslmode=require
# DISABLE_EMBEDDED_PG=true

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=4
RAG_MIN_SCORE=0.32
